# ============================================================
# Python Master 12 - Biến Môi Trường
# Sao chép file này thành .env.local và điền các giá trị
# Copy this file to .env.local and fill in the values
# ============================================================

# --- Supabase Configuration ---
# URL của Supabase project (lấy từ Settings > API trong Supabase Dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key cho client-side access (lấy từ Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key cho server-side operations (KHÔNG chia sẻ key này!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Database ---
# Connection string trực tiếp đến PostgreSQL (dùng cho migrations và queries phức tạp)
# Lấy từ Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# --- NextAuth.js Configuration ---
# URL gốc của ứng dụng (thay đổi khi deploy production)
NEXTAUTH_URL=http://localhost:3000

# Secret key cho JWT signing (tạo bằng lệnh: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# --- Google OAuth ---
# Tạo credentials tại: https://console.cloud.google.com/apis/credentials
# Thêm Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- OpenAI API (AI Tutor - PyMate) ---
# API key từ https://platform.openai.com/api-keys
# Dùng cho tính năng AI Tutor, giải thích code, debug hỗ trợ
OPENAI_API_KEY=sk-your-openai-api-key

# --- Judge0 API (Code Execution Sandbox) ---
# URL của Judge0 CE API (self-hosted hoặc RapidAPI)
# Đăng ký tại: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# API key cho Judge0 (nếu dùng RapidAPI)
JUDGE0_API_KEY=your-judge0-api-key

# --- Email Service (SendGrid hoặc Resend) ---
# API key cho dịch vụ gửi email (dùng cho reset password, thông báo)
# SendGrid: https://sendgrid.com hoặc Resend: https://resend.com
EMAIL_API_KEY=your-email-api-key

# Địa chỉ email gửi đi (phải được xác minh với dịch vụ email)
EMAIL_FROM=noreply@pythonmaster12.com
